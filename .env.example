# Configuración de la aplicación
APP_NAME="Travel Assistant Chatbot API"
APP_VERSION="1.0.0"
DEBUG=True

# Servidor
HOST=0.0.0.0
PORT=8000

# Base de datos
DATABASE_URL=sqlite:///./travel_chatbot.db

# Google Gemini API
# IMPORTANTE: Obtén tu API key en https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# Parámetros del modelo
MAX_TOKENS=2048
TEMPERATURE=0.8
TOP_P=0.95
TOP_K=40

# Sistema de conversación
CONVERSATION_MEMORY_TURNS=10

# Cache
CACHE_TTL=3600
